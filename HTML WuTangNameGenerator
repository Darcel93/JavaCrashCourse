<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wu-Tang Name Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@400;700&family=Special+Elite&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --wu-yellow: #F5C518;
    --wu-gold: #D4A017;
    --wu-dark: #0a0a0a;
    --wu-red: #8B0000;
  }

  body {
    min-height: 100vh;
    background: var(--wu-dark);
    color: #fff;
    font-family: 'Oswald', sans-serif;
    overflow-x: hidden;
    position: relative;
  }

  /* ── BACKGROUND IMAGE ── */
  .bg-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-color: #464646;
    background-image: url('data:image/jpeg;base64,');
    background-repeat: repeat;
    background-size: 600px auto;
    filter: brightness(0.7) saturate(0.85);
  }

  /* ── GRAIN OVERLAY ── */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.12;
  }

  /* ── VIGNETTE ── */
  .vignette {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.5) 100%);
  }

  /* ── MAIN CONTENT ── */
  .main {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  /* ── WU LOGO SVG ── */
  .wu-logo {
    width: 120px;
    height: 120px;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 30px rgba(245, 197, 24, 0.5));
    animation: logoFloat 4s ease-in-out infinite;
  }

  @keyframes logoFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ── TITLE ── */
  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.8rem, 8vw, 6rem);
    letter-spacing: 0.08em;
    color: var(--wu-yellow);
    text-shadow:
      3px 3px 0 #000,
      -2px -2px 0 #000,
      2px -2px 0 #000,
      -2px 2px 0 #000,
      0 0 20px rgba(0,0,0,0.9),
      0 0 60px rgba(0,0,0,0.7);
    text-align: center;
    line-height: 1;
    margin-bottom: 0.25rem;
    background: rgba(0,0,0,0.6);
    padding: 0.3rem 1.2rem;
    border-radius: 4px;
  }

  .subtitle {
    font-family: 'Special Elite', cursive;
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  /* ── CARD ── */
  .card {
    background: rgba(10, 10, 10, 0.85);
    border: 1px solid rgba(245, 197, 24, 0.15);
    border-radius: 2px;
    padding: 2.5rem 3rem;
    width: 100%;
    max-width: 520px;
    backdrop-filter: blur(20px);
    box-shadow:
      0 30px 80px rgba(0,0,0,0.7),
      inset 0 1px 0 rgba(245, 197, 24, 0.08);
  }

  .card label {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--wu-yellow);
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .card input {
    width: 100%;
    padding: 0.9rem 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(245, 197, 24, 0.2);
    border-radius: 2px;
    color: #fff;
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    outline: none;
    transition: border-color 0.3s, box-shadow 0.3s;
    margin-bottom: 1.5rem;
  }

  .card input:focus {
    border-color: var(--wu-yellow);
    box-shadow: 0 0 15px rgba(245, 197, 24, 0.15);
  }

  .card input::placeholder {
    color: rgba(255,255,255,0.2);
  }

  /* ── GENERATE BUTTON ── */
  .btn-generate {
    width: 100%;
    padding: 1rem;
    background: var(--wu-yellow);
    color: var(--wu-dark);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.15em;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.3s;
  }

  .btn-generate:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(245, 197, 24, 0.35);
  }

  .btn-generate:active {
    transform: translateY(0);
  }

  .btn-generate::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: translateX(-100%);
    transition: none;
  }

  .btn-generate:hover::after {
    animation: shimmer 0.6s ease forwards;
  }

  @keyframes shimmer {
    to { transform: translateX(100%); }
  }

  /* ── RESULT ── */
  .result-area {
    margin-top: 2rem;
    text-align: center;
    min-height: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s, transform 0.6s;
  }

  .result-area.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .result-label {
    font-family: 'Special Elite', cursive;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.75rem;
  }

  .result-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3rem);
    color: var(--wu-yellow);
    text-shadow: 0 0 40px rgba(245, 197, 24, 0.4);
    line-height: 1.15;
    animation: nameReveal 0.5s ease-out;
  }

  .result-title {
    font-family: 'Special Elite', cursive;
    font-size: clamp(0.9rem, 2.5vw, 1.15rem);
    color: rgba(255,255,255,0.6);
    margin-top: 0.4rem;
    letter-spacing: 0.12em;
  }

  @keyframes nameReveal {
    from { opacity: 0; transform: scale(0.85); filter: blur(6px); }
    to { opacity: 1; transform: scale(1); filter: blur(0); }
  }

  /* ── FOOTER TAGLINE ── */
  .tagline {
    margin-top: 3rem;
    font-family: 'Special Elite', cursive;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 560px) {
    .card { padding: 1.8rem 1.5rem; }
  }
</style>
</head>
<body>

<div class="bg-backdrop"></div>
<div class="grain"></div>
<div class="vignette"></div>

<!-- Main Content -->
<div class="main">

  <h1>Wu-Tang Name Generator</h1>
  <p class="subtitle">Enter the 36 Chambers</p>

  <div class="card">
    <label for="firstName">First Name</label>
    <input type="text" id="firstName" placeholder="Your first name" autocomplete="off" />

    <label for="lastName">Last Name</label>
    <input type="text" id="lastName" placeholder="Your last name" autocomplete="off" />

    <button class="btn-generate" id="generateBtn" onclick="generateName()">
      GENERATE YOUR WU-TANG NAME
    </button>

    <div class="result-area" id="resultArea">
      <div class="result-label">Your Wu-Tang Name Is</div>
      <div class="result-name" id="resultName"></div>
      <div class="result-title" id="resultTitle"></div>
    </div>
  </div>

  <p class="tagline">Wu-Tang is forever</p>
</div>

<script>
  // ── Name Arrays (from Java code) ──
  const firstNames = [
    "Crimson", "Shadow", "Iron", "Storm", "Silent", "Ruthless",
    "Draco", "Phantom", "Steel", "Nova", "Masta", "Dragon",
    "Tiger", "Ronin", "Mantis", "Cipher", "Killah", "Lotus",
    "Katana", "Live", "Monarch", "God"
  ];

  const titles = [
    "The Chamber Guardian", "The Beat Assassin", "The Rhythm Monk",
    "The Flow General", "The Iron Lyricist", "Hidden Warrior",
    "Of The Street Philosophers", "Champion of the Shadows",
    "Strategist Supreme", "The Silent Conqueror", "The Elder God"
  ];

  function randomIndex(len) {
    return Math.floor(Math.random() * len);
  }

  function generateName() {
    const userFirst = document.getElementById('firstName').value.trim();
    const userLast = document.getElementById('lastName').value.trim();

    if (!userFirst || !userLast) {
      document.getElementById('firstName').style.borderColor = !userFirst ? '#8B0000' : '';
      document.getElementById('lastName').style.borderColor = !userLast ? '#8B0000' : '';
      return;
    }

    document.getElementById('firstName').style.borderColor = '';
    document.getElementById('lastName').style.borderColor = '';

    // Pick first name
    const wuFirst = firstNames[randomIndex(firstNames.length)];

    // Pick second name, ensuring it's different (mirrors the Java while-loop)
    let wuSecond;
    do {
      wuSecond = firstNames[randomIndex(firstNames.length)];
    } while (wuSecond === wuFirst);

    // Pick title
    const wuTitle = titles[randomIndex(titles.length)];

    // Display
    const resultArea = document.getElementById('resultArea');
    const resultName = document.getElementById('resultName');
    const resultTitle = document.getElementById('resultTitle');

    resultArea.classList.remove('visible');

    setTimeout(() => {
      resultName.textContent = wuFirst + " " + wuSecond;
      resultTitle.textContent = wuTitle;
      resultName.style.animation = 'none';
      resultName.offsetHeight; // reflow
      resultName.style.animation = '';
      resultArea.classList.add('visible');
    }, 100);
  }

  // Allow Enter key
  document.querySelectorAll('.card input').forEach(input => {
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') generateName();
    });
  });
</script>
</body>
</html>
